# Python virtual environments
**/.venv/
**/__pycache__/
*.pyc

# Tool outputs (clips, manifests, sampled frames)
**/output/

# Source / exported footage — keep large media out of git
*.mp4
*.mov
*.m4v
*.avi
*.mkv
*.webm
*.mts
*.m2ts
*.jpg
*.jpeg
*.png
*.heic
*.aae
*.mp3
*.m4a

# Local working folders (personal footage/photos/music — never commit)
**/input/
**/book_photos/
**/maps/
**/music/
**/_album_photos/

# Ship the curated royalty-free shelf with the web app (Pixabay license permits redistribution).
# Must re-include the dir before the files, since **/music/ excludes it.
!reel-web/music/
!reel-web/music/*.mp3
!reel-web/music/library.json

# Secrets
.env

# OS cruft
.DS_Store
